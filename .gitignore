# dependencies
**/node_modules/

# Expo / React Native
frontend/.expo/
frontend/dist/
frontend/web-build/

# Native build artifacts (if ever prebuilt)
frontend/ios/
frontend/android/

# Metro
**/.metro-health-check*

# debug
**/npm-debug.*
**/yarn-debug.*
**/yarn-error.*

# macOS
**/.DS_Store

# Windows
**/Thumbs.db

# TypeScript
**/*.tsbuildinfo

# Env (do not commit real secrets)
backend/.env
backend/.env.local
backend/.env.*.local

# Uploads (keep folder via .gitkeep)
backend/uploads/*
!backend/uploads/.gitkeep

